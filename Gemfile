source "https://rubygems.org"

# GitHub Pages keeps Jekyll, the minima theme, and supported plugins pinned to
# the versions actually used by the github-pages build. Using this gem locally
# is the simplest way to match what gets rendered on github.io.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
end

# Performance / compatibility shims that GitHub Pages recommends.
gem "webrick"
